# ══════════════════════════════════════════════════════════════
# GCD Frontend — Environment Variables
# Copy to .env.local — NEVER commit this file
# ══════════════════════════════════════════════════════════════

# ── Backend API URL ───────────────────────────────────────────
# This is the ONLY env var exposed to the browser (NEXT_PUBLIC_)
# All other env vars must NOT have NEXT_PUBLIC_ prefix
NEXT_PUBLIC_API_URL=https://gcd-backend-production.up.railway.app

# ── NEVER put these in frontend env: ─────────────────────────
# DATABASE_URL, JWT_SECRET, SUPABASE_SERVICE_KEY
# Any key with NEXT_PUBLIC_ is bundled into the browser JS
